# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=store.mangaroa.org
SHOPIFY_STOREFRONT_TOKEN=

# Airtable (for bulk order form)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=app8H6Ok8BVYKYCGz
BULK_ORDER_TABLE=Bulk Meat Orders

# Analytics (optional)
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=

# Set to 'true' to use mock product data
USE_MOCK_DATA=

# Google Search Console verification (optional)
# Paste the `content` value from GSC's HTML-tag verification method.
# Layout.astro renders <meta name="google-site-verification"> only when this is set.
GOOGLE_SITE_VERIFICATION=
