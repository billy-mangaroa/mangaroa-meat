---

---

<footer class="bg-mangaroa-charcoal text-white mt-auto safe-bottom">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8">
      <!-- About -->
      <div class="col-span-2 md:col-span-1 order-1 md:order-none">
        <img src="/logo.png" alt="Mangaroa Farms" class="h-11 sm:h-14 w-auto mb-3 sm:mb-4 invert" />
        <p class="text-mangaroa-gray-light text-xs sm:text-sm leading-relaxed">
          Home-grown, home-processed beef and lamb from our regenerative farm
          in Te Awa Kairangi / the Hutt Valley, Upper Hutt, Wellington.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="order-2 md:order-none">
        <h3 class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-3 sm:mb-4">Meat</h3>
        <ul class="space-y-2 sm:space-y-2.5">
          <li>
            <a href="/" class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors text-xs sm:text-sm py-1 inline-block">
              Our Story
            </a>
          </li>
          <li>
            <a href="/order" class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors text-xs sm:text-sm py-1 inline-block">
              Order Online
            </a>
          </li>
          <li>
            <a href="/bulk" class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors text-xs sm:text-sm py-1 inline-block">
              Bulk Orders
            </a>
          </li>
          <li>
            <a href="/faq" class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors text-xs sm:text-sm py-1 inline-block">
              FAQ
            </a>
          </li>
          <li>
            <a href="https://mangaroa.org/visit-us" class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors text-xs sm:text-sm py-1 inline-block">
              Visit the Farm Shop
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact & Social -->
      <div class="order-3 md:order-none">
        <h3 class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-3 sm:mb-4">Connect</h3>
        <div class="flex gap-3 sm:gap-4 mb-3 sm:mb-4">
          <a
            href="https://www.instagram.com/mangaroafarms"
            target="_blank"
            rel="noopener noreferrer"
            class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors p-1.5 -m-1.5"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/mangaroafarms"
            target="_blank"
            rel="noopener noreferrer"
            class="text-mangaroa-gray-light hover:text-white active:text-white transition-colors p-1.5 -m-1.5"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
        <p class="text-mangaroa-gray-light text-xs sm:text-sm">
          29 Mangaroa Valley Road<br />
          Upper Hutt, Wellington 5371
        </p>
      </div>
    </div>

    <div class="border-t border-mangaroa-gray mt-6 sm:mt-8 pt-6 sm:pt-8 text-center">
      <p class="text-mangaroa-gray text-xs sm:text-sm">
        &copy; {new Date().getFullYear()} Mangaroa Farms. All rights reserved.
      </p>
    </div>
  </div>
</footer>
