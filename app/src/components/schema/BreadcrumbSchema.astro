---
/**
 * BreadcrumbList schema — renders JSON-LD breadcrumbs.
 * Pass an array of { name, href } items (Home is auto-prepended).
 */
interface Props {
  items: { name: string; href: string }[];
}

const { items } = Astro.props;

const breadcrumbs = [
  { name: 'Home', href: 'https://meat.mangaroa.org/' },
  ...items.map((item) => ({
    name: item.name,
    href: item.href.startsWith('http') ? item.href : `https://meat.mangaroa.org${item.href}`,
  })),
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.href,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
