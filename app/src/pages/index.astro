---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getMeatProducts } from '../lib/shopify';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';
import FAQPageSchema from '../components/schema/FAQPageSchema.astro';

const KLAVIYO_PUBLIC_KEY = 'QVwuJb';

const allProducts = await getMeatProducts().catch(() => []);

const pickProduct = (patterns: RegExp[]) =>
  allProducts.find(p => patterns.some(re => re.test(p.title)));

const featuredPicks = [
  pickProduct([/sirloin/i]),
  pickProduct([/lamb rack/i, /rack of lamb/i, /frenched rack/i]),
  pickProduct([/sausage/i, /snarler/i, /banger/i]),
].filter(Boolean) as typeof allProducts;

const featuredProducts = featuredPicks.length === 3 ? featuredPicks : allProducts.slice(0, 3);

const stats = [
  { n: '100%', u: 'Pasture-raised', icon: 'leaf' },
  { n: '0', u: 'Hormones, antibiotics, GMOs', icon: 'shield' },
  { n: 'Family', u: 'Owned & operated', icon: 'pin' },
  { n: 'Every cut', u: 'Processed on-farm', icon: 'home' },
];

const meatTypes = [
  {
    name: 'Beef',
    image: '/meat/product-hero.webp',
    alt: 'Mangaroa Angus cow grazing on pasture',
    body1: 'Our beef is primarily Angus or Angus Cross. We bring cattle in young and butcher at around three years old (~500kg), for consistent carcass weight, deeper flavour, and increased marbling. Some are butchered at 18 months.',
    body2: 'Low stress handling throughout. Fed kelp, salt, and mineral mixes alongside our diverse pastures, producing premium, nutrient-dense meat.',
  },
  {
    name: 'Lamb',
    image: '/meat/farm-ewe-lamb.jpg',
    alt: 'A Mangaroa ewe and her lamb resting on pasture',
    body1: 'Coopworth sheep as the basis of our ewe flock. We use a Suffolk ram to breed for a quality meat breed and a better eating experience. We only butcher ewe lambs, something that separates us from supermarket and export lamb.',
    body2: 'Minimal management and low stress handling at lambing gives lambs the best start in life. Fed kelp, salt, and mineral mixes alongside our diverse pastures, producing nutrient-dense, tender, ethically raised meat.',
  },
];

const pillars = [
  {
    kicker: 'Home-processed',
    title: 'Our crew, our craft, on-farm.',
    body1: 'Professional slaughter happens through Preston\'s, a trusted part of the chain. Then the carcasses come home, where Rob and our local crew handle the butchery and processing.',
    body2: 'Every cut is prepared by people who know the farm, the animals, and the land. A short chain, more care at every step.',
  },
  {
    kicker: 'Regenerative',
    title: 'Raised in alignment with nature and human health.',
    body1: 'Pasture-raised in Mangaroa Valley with rotational grazing, virtual fencing, and diverse cover crops. The same practices that build soil also grow good meat.',
    body2: 'The landscapes of Aotearoa were once covered in great forests, with streams and rivers held by those forests as a natural filtration system. That\'s why we fence and plant natives along our riparian and critical source areas.',
  },
  {
    kicker: 'Traceable',
    title: 'Every cut, back to the paddock.',
    body1: 'No anonymous supply chain, no commodity feedlot meat. Every animal is raised on this farm, by this crew, on these paddocks.',
    body2: 'You can drive past the farm where your dinner was raised. You can meet the people who handled it. That\'s the whole point.',
  },
];

const linkClass = 'text-mangaroa-gold hover:text-mangaroa-gold-dark underline underline-offset-2';

const faqs = [
  {
    q: 'What does "home-processed" mean?',
    a: `Our beef and lamb are raised on Mangaroa's regenerative pastures in the valley. After professional slaughter, the carcasses come home to our local crew who handle all the butchery and processing. Shorter chain, more care, fresher meat.`,
  },
  {
    q: 'What cuts are available?',
    a: `Standard retail cuts: steaks, mince, sausages, chops, roasts, and more. The range varies week to week depending on what has been processed. Drop in to the shop to see what's in stock, or <a href="/order" class="${linkClass}">check online</a> for current availability.`,
  },
  {
    q: 'How do I order online?',
    a: `Visit our <a href="/order" class="${linkClass}">online shop</a> to browse what is available. Select your cuts, place your order, and pick up from the farm shop at a time that works for you.`,
  },
  {
    q: 'Can I order a whole lamb or side of beef?',
    a: `Yes. We take expressions of interest for whole animals, half animals, and custom bulk orders. Whole lamb starts from approximately $350-450 (butchered). Side of beef pricing varies by weight. <a href="/bulk" class="${linkClass}">Register your interest</a> and we'll be in touch.`,
  },
  {
    q: 'How should I store fresh meat at home?',
    a: `Keep fresh cuts refrigerated at or below 4°C and use within 3-5 days. For longer storage, freeze on the day you collect. Well-wrapped meat keeps for several months. Mince and sausages are best used within 2 days fresh, or frozen straight away.`,
  },
  {
    q: 'How far ahead should I order a whole lamb or side of beef?',
    a: `Bulk orders depend on the processing schedule, so timing varies. As a rough guide, allow 2-4 weeks from the day you confirm to pickup. For a specific date, <a href="mailto:online@mangaroa.org" class="${linkClass}">get in touch</a> as early as you can and we will line it up.`,
  },
  {
    q: 'Can I get meat shipped to me?',
    a: `We can ship butchered orders within New Zealand. Unbutchered carcasses are local pickup only. Let us know your preference on the <a href="/bulk" class="${linkClass}">bulk order form</a> and we will work out the best option.`,
  },
  {
    q: 'Are your sausages gluten-free? What is in them?',
    a: `Sausage recipes vary by batch. Ingredients are listed on the product label in the shop. If you have a specific allergy or dietary need, ask the staff or <a href="mailto:online@mangaroa.org" class="${linkClass}">get in touch</a> before ordering. We're happy to confirm what is in the batch you are buying.`,
  },
  {
    q: 'Where exactly does the meat come from?',
    a: `Every cut comes from animals raised on Mangaroa Farms, 29 Mangaroa Valley Road, Upper Hutt. You can <a href="https://mangaroa.org/visit-us" class="${linkClass}">visit the farm</a>, see the paddocks, and meet the team. Rob manages both the farm and the butchery.`,
  },
  {
    q: 'What if something I ordered online is not available?',
    a: `We try to keep listings accurate, but the cabinet changes week to week. If a cut you ordered is not available when we go to fulfil it, we will be in touch. You can swap, refund the difference, or hold for the next batch.`,
  },
];
---

<Layout title="Fresh Meat - Mangaroa Farms" description="Home-grown, home-processed beef and lamb from Mangaroa Farms. Raised on regenerative pastures in Mangaroa Valley, processed right here by our local crew. Our goal is to create the highest quality meat products, direct into kiwi homes, while restoring the vitality of the land and the Mangaroa River">

  <Fragment slot="head">
    <LocalBusinessSchema />
    <FAQPageSchema faqs={faqs} />
  </Fragment>

  <main class="flex-1 bg-mangaroa-cream">

    <!-- ═══ COMING SOON ANNOUNCEMENT BAR (above nav) ═══ -->
    <div class="relative z-30 bg-mangaroa-gold-dark text-white px-4 py-3 sm:py-3.5 text-center text-[13px] sm:text-[14px] leading-snug">
      <span class="inline-block font-bold uppercase tracking-[0.2em] text-[10px] sm:text-[11px] mr-2 px-2 py-0.5 bg-white/15 rounded-sm">Coming Soon</span>
      Fresh meat from our new on-farm butchery launches in a few weeks. Frozen cuts from our previous butcher are available now in the farm shop.
    </div>

    <!-- ═══ HERO (transparent nav overlaid inside) ═══ -->
    <section class="relative bg-mangaroa-charcoal overflow-hidden isolate">
      <Header />
      <picture>
        <source media="(max-width: 768px)" srcset="/meat/hero-800.webp" type="image/webp" />
        <source srcset="/meat/hero-1600.webp" type="image/webp" />
        <source media="(max-width: 768px)" srcset="/meat/hero-800.jpg" type="image/jpeg" />
        <img src="/meat/hero-800.jpg" alt="Pasture-raised Angus cow at Mangaroa Farms" width="1600" height="900" class="hero-bg absolute inset-0 w-full h-full object-cover" fetchpriority="high" loading="eager" decoding="async" />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/55 to-black/90"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_15%,rgba(201,162,39,0.22),transparent_60%)] mix-blend-overlay"></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 py-28 sm:py-44 text-center">
        <p class="text-[14px] sm:text-base uppercase tracking-[0.3em] text-white/85 mb-7 font-medium">Mangaroa Farms - Fresh Meat</p>
        <h1 class="font-bold text-white leading-[1.02] tracking-tight mb-7" style="font-size:clamp(2.5rem,7vw,4.75rem); font-family:var(--font-display);">
          Home-Grown,<br />
          <span class="text-white italic font-medium">Home-Processed.</span>
        </h1>
        <p class="text-xl sm:text-2xl text-white max-w-2xl mx-auto leading-[1.5] mb-6 italic font-medium" style="font-family:var(--font-display);">
          Our goal is to create the highest quality meat products, direct into kiwi homes, while restoring the vitality of the land and the Mangaroa River.
        </p>
        <div class="flex justify-center">
          <a href="#how-to-buy" class="group inline-flex items-center gap-2 bg-mangaroa-gold hover:bg-mangaroa-gold-dark text-white px-8 py-4 rounded-full text-base font-semibold transition-all shadow-lg shadow-black/20 hover:shadow-xl hover:-translate-y-0.5" style="min-height:48px;">
            See how to get it
            <span aria-hidden="true" class="transition-transform group-hover:translate-y-0.5">↓</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ STATS STRIP — with vector icons ═══ -->
    <section class="bg-white border-b border-mangaroa-gray-light/70">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-5 text-center">
          {stats.map(({ n, u, icon }) => (
            <div data-reveal class="flex flex-col items-center">
              <div class="w-10 h-10 sm:w-12 sm:h-12 mb-3 text-mangaroa-gold flex items-center justify-center">
                {icon === 'leaf' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.8.66c0 6-1.4 11-9 11.4-2 0-2.5 0-3.4-.6"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
                )}
                {icon === 'shield' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-full h-full"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/></svg>
                )}
                {icon === 'pin' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-full h-full"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s-7-7-7-13a7 7 0 0 1 14 0c0 6-7 13-7 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {icon === 'home' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-full h-full"><path stroke-linecap="round" stroke-linejoin="round" d="M3 11l9-8 9 8v9a2 2 0 0 1-2 2h-4v-7h-6v7H5a2 2 0 0 1-2-2v-9z"/></svg>
                )}
              </div>
              <div class="text-3xl sm:text-4xl font-semibold text-mangaroa-charcoal tracking-tight" style="font-family:var(--font-display);">{n}</div>
              <div class="text-xs sm:text-sm text-mangaroa-gray mt-1 leading-snug">{u}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ LEAD-IN EDITORIAL — cream ═══ -->
    <section class="bg-mangaroa-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-14 items-center">
          <div class="md:col-span-5 order-2 md:order-1" data-reveal>
            <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-mangaroa-earth">
              <img src="/meat/food-raw-flatlay.webp" alt="Raw Mangaroa beef cuts laid out on a wooden board" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
            </div>
          </div>
          <div class="md:col-span-7 order-1 md:order-2">
            <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-6 font-medium" data-reveal>What this is</p>
            <p class="lede text-mangaroa-charcoal leading-[1.65]" data-reveal>
              <span class="dropcap">M</span>eat from a farm that focuses on nutritional value. Beef and lamb raised alongside the Mangaroa river, by people who have deep connection to the land. Then processed right here locally, not shipped through an anonymous supply chain.
            </p>
            <p class="text-lg text-mangaroa-charcoal leading-[1.65] mt-5" data-reveal>
              We pride ourselves on prime honest cuts from a small farm outside of Wellington. You can drive past the paddock where your dinner was raised, and meet the people who handled it. That's the promise of local food.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ THREE WAYS TO GET YOUR MEAT paper ═══ -->
    <section id="how-to-buy" class="bg-mangaroa-paper border-y border-mangaroa-gray-light/70 scroll-mt-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28">
        <div class="max-w-2xl mb-12 sm:mb-16" data-reveal>
          <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">Three ways to get it</p>
          <h2 class="text-3xl sm:text-5xl font-semibold text-mangaroa-charcoal leading-[1.05] tracking-tight mb-5">Order with us.</h2>
          <p class="text-lg text-mangaroa-gray leading-[1.65]">
            Buy online, drop into the shop, or fill the freezer with a whole animal.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">

          <a href="/order" class="group relative bg-white border border-mangaroa-gray-light/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all flex flex-col" data-reveal>
            <div class="aspect-[16/10] overflow-hidden bg-mangaroa-charcoal relative">
              <img src="/meat/food-lamb-ribs.jpg" alt="Mangaroa lamb cuts ready for pickup" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" loading="lazy" onerror="this.style.display='none'" />
              <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 bg-mangaroa-gold-dark/95 text-white text-[10px] uppercase tracking-[0.2em] font-bold rounded-sm backdrop-blur-sm">Coming Soon</span>
            </div>
            <div class="p-6 sm:p-7 flex flex-col flex-1">
              <p class="text-[12px] uppercase tracking-[0.25em] text-mangaroa-gold font-bold mb-3">01 / Online</p>
              <h3 class="text-2xl sm:text-3xl font-semibold text-mangaroa-charcoal leading-[1.05] mb-3">Order for shop pickup</h3>
              <p class="text-lg text-mangaroa-gray leading-[1.65] mb-6 flex-1">
                Browse our wide-ranging meat selection online. Shipping North Island-wide, or pick up from the shop. Fresh meat from the new butchery launches in a few weeks.
              </p>
              <span class="inline-flex items-center justify-center gap-2 bg-mangaroa-charcoal group-hover:bg-mangaroa-gold text-white px-6 py-3 rounded-full text-[14px] font-semibold transition-colors w-full" style="min-height:44px;">
                Shop online
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>

          <a href="https://mangaroa.org/visit-us" class="group relative bg-white border border-mangaroa-gray-light/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all flex flex-col" data-reveal>
            <div class="aspect-[16/10] overflow-hidden bg-mangaroa-charcoal relative">
              <img src="/meat/food-sirloin.jpg" alt="Mangaroa beef sirloin sliced and ready to serve" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" loading="lazy" onerror="this.style.display='none'" />
              <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 bg-mangaroa-charcoal/90 text-white text-[10px] uppercase tracking-[0.2em] font-bold rounded-sm backdrop-blur-sm">Open Now</span>
            </div>
            <div class="p-6 sm:p-7 flex flex-col flex-1">
              <p class="text-[12px] uppercase tracking-[0.25em] text-mangaroa-gold font-bold mb-3">02 / In person</p>
              <h3 class="text-2xl sm:text-3xl font-semibold text-mangaroa-charcoal leading-[1.05] mb-3">Visit the farm shop</h3>
              <p class="text-lg text-mangaroa-gray leading-[1.65] mb-6 flex-1">
                Frozen cuts from our previous butcher are available now in the shop cabinet. Fresh on-farm meat coming in a few weeks. Open during regular shop hours.
              </p>
              <span class="inline-flex items-center justify-center gap-2 bg-mangaroa-charcoal group-hover:bg-mangaroa-gold text-white px-6 py-3 rounded-full text-[14px] font-semibold transition-colors w-full" style="min-height:44px;">
                Shop hours &amp; directions
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
              </span>
            </div>
          </a>

          <a href="/bulk" class="group relative bg-white border border-mangaroa-gray-light/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all flex flex-col" data-reveal>
            <div class="aspect-[16/10] overflow-hidden bg-mangaroa-charcoal relative">
              <img src="/meat/cta-bulk.webp" alt="Mangaroa Angus herd in pasture" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" loading="lazy" onerror="this.style.display='none'" />
              <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 bg-mangaroa-charcoal/90 text-white text-[10px] uppercase tracking-[0.2em] font-bold rounded-sm backdrop-blur-sm">Now Taking Interest</span>
            </div>
            <div class="p-6 sm:p-7 flex flex-col flex-1">
              <p class="text-[12px] uppercase tracking-[0.25em] text-mangaroa-gold font-bold mb-3">03 / Whole or half</p>
              <h3 class="text-2xl sm:text-3xl font-semibold text-mangaroa-charcoal leading-[1.05] mb-3">Whole lamb, side of beef</h3>
              <p class="text-lg text-mangaroa-gray leading-[1.65] mb-6 flex-1">
                Register your interest now and you'll be first in line when the new on-farm butchery is ready to fill freezers. Tell us what you need.
              </p>
              <span class="inline-flex items-center justify-center gap-2 bg-mangaroa-charcoal group-hover:bg-mangaroa-gold text-white px-6 py-3 rounded-full text-[14px] font-semibold transition-colors w-full" style="min-height:44px;">
                Register interest
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- ═══ WIDE BANNER DIVIDER — lambing on Mangaroa pasture, no text ═══ -->
    <section class="relative w-full bg-mangaroa-charcoal overflow-hidden isolate h-[260px] sm:h-[420px] lg:h-[560px]">
      <img src="/meat/banner-sheep-lambing.webp" alt="Ewe and lamb on Mangaroa Farms pasture during spring lambing" class="absolute inset-0 w-full h-full object-cover block" style="object-position: center 65%;" loading="lazy" />
      <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-mangaroa-charcoal/30 to-transparent"></div>
    </section>

    <!-- ═══ BORN & GRAZED IN ALIGNMENT WITH NATURE — 4-point principles (cream) ═══ -->
    <section class="bg-mangaroa-cream">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
        <div class="max-w-3xl mb-12 sm:mb-14" data-reveal>
          <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">Our way</p>
          <h2 class="text-3xl sm:text-5xl font-semibold text-mangaroa-charcoal leading-[1.05] tracking-tight mb-5">Born &amp; grazed in alignment with nature.</h2>
          <p class="text-lg text-mangaroa-charcoal leading-[1.65]">
            Mangaroa Farms livestock are raised naturally with care, in alignment with regenerative principles. Our intention is to produce premium quality and superior tasting meats. We start by selecting high-quality genetics, such as Angus beef. Then we nurture those on a diet of lush, diverse pasture, our meat is free from stress, added hormones, GMOs, and antibiotics.
          </p>
          <p class="text-lg text-mangaroa-gray leading-[1.65] mt-4">
            We pride ourselves in raising quality livestock and premium tasting kai for our local community, as part of an interconnected ecosystem for soil regeneration. We're a breeding finishing unit, meaning our cattle and sheep spend their entire lives here on the farm.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-mangaroa-gray-light/60 border border-mangaroa-gray-light/60" data-reveal>
          <div class="bg-mangaroa-cream p-7 sm:p-8 group hover:bg-white transition-colors duration-500">
            <div class="w-10 h-10 mb-5 text-mangaroa-charcoal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.8.66c0 6-1.4 11-9 11.4-2 0-2.5 0-3.4-.6"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
            </div>
            <h3 class="text-lg sm:text-xl font-semibold text-mangaroa-charcoal leading-[1.2] mb-3">Grass-fed, pasture-grazed</h3>
            <p class="text-[15px] text-mangaroa-gray leading-[1.65]">Our focus is on nurturing biodiverse, living soil. This creates rich nutritional grass for our animals to graze.</p>
          </div>
          <div class="bg-mangaroa-cream p-7 sm:p-8 group hover:bg-white transition-colors duration-500">
            <div class="w-10 h-10 mb-5 text-mangaroa-charcoal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 12a9 9 0 1 1-9-9c2.5 0 4.78 1 6.45 2.55"/><polyline points="21 3 21 9 15 9"/></svg>
            </div>
            <h3 class="text-lg sm:text-xl font-semibold text-mangaroa-charcoal leading-[1.2] mb-3">Raised with regenerative principles</h3>
            <p class="text-[15px] text-mangaroa-gray leading-[1.65]">Our livestock are raised with ecology as a first principle. We nurture land, air and all living beings with our actions.</p>
          </div>
          <div class="bg-mangaroa-cream p-7 sm:p-8 group hover:bg-white transition-colors duration-500">
            <div class="w-10 h-10 mb-5 text-mangaroa-charcoal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg>
            </div>
            <h3 class="text-lg sm:text-xl font-semibold text-mangaroa-charcoal leading-[1.2] mb-3">No synthetic hormones, GMOs, or antibiotics</h3>
