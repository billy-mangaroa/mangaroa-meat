---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';

// Show only LINKED, non-draft posts on the index
const posts = (await getCollection('blog', ({ data }) => data.status === 'linked' && !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog - Mangaroa Farms" description="Stories, guides, and insights from Mangaroa Farms — regenerative meat, grass-fed farming, and the land behind your food.">

  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Blog', href: '/blog' }]} />
  </Fragment>

  <main>
    <section class="bg-mangaroa-charcoal text-white relative overflow-hidden isolate pt-32 sm:pt-40 pb-12 sm:pb-16">
      <Header />
      <div class="absolute inset-0 bg-gradient-to-b from-mangaroa-charcoal/90 to-mangaroa-charcoal/70"></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">From the paddock</p>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight">Blog</h1>
      </div>
    </section>

    <section class="bg-mangaroa-cream">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
        {posts.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-mangaroa-gray text-lg mb-4">No posts yet. Check back soon.</p>
            <a href="/" class="text-mangaroa-gold hover:text-mangaroa-gold-dark underline underline-offset-2">Back to home</a>
          </div>
        ) : (
          <div class="space-y-8 sm:space-y-10">
            {posts.map((post) => {
              const date = post.data.pubDate.toLocaleDateString('en-NZ', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              });
              return (
                <a href={`/blog/${post.id}`} class="group block bg-white border border-mangaroa-gray-light/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all">
                  <div class="p-6 sm:p-8">
                    <p class="text-[12px] uppercase tracking-[0.2em] text-mangaroa-gold font-bold mb-2">{post.data.pillar.replace('-', ' ')}</p>
                    <h2 class="text-xl sm:text-2xl font-semibold text-mangaroa-charcoal leading-[1.15] mb-3 group-hover:text-mangaroa-gold-dark transition-colors">{post.data.title}</h2>
                    <p class="text-mangaroa-gray leading-[1.65] mb-3 line-clamp-2">{post.data.description}</p>
                    <p class="text-[13px] text-mangaroa-gray/70">{date}</p>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
