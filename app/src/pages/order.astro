---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getMeatProducts, formatPrice } from '../lib/shopify';
import ProductSchema from '../components/schema/ProductSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';

const products = await getMeatProducts();

// Categorise each product into a cut group
function getCut(title: string, tags: string[]): string {
  const t = title.toLowerCase();
  const allTags = tags.map(x => x.toLowerCase());
  if (t.includes('mince')) return 'mince';
  if (t.includes('sausage') || t.includes('chorizo')) return 'sausage';
  if (t.includes('chop') || t.includes('cutlet')) return 'chops';
  if (t.includes('rib') || t.includes('osso')) return 'slow-cook';
  if (t.includes('roast') || t.includes('leg') || t.includes('shoulder')) return 'roast';
  if (t.includes('diced') || t.includes('stew') || t.includes('shank') || t.includes('schnitzel') || t.includes('blade') || t.includes('chuck') || t.includes('brisket') || t.includes('bucco')) return 'slow-cook';
  if (t.includes('steak') || t.includes('fillet') || t.includes('rump') || t.includes('sirloin') || t.includes('scotch') || t.includes('porterhouse') || t.includes('ribeye') || t.includes('eye')) return 'steak';
  return 'other';
}

function getType(productType: string, title: string): string {
  const pt = (productType || '').toLowerCase();
  const t = title.toLowerCase();
  if (pt.includes('lamb') || t.includes('lamb')) return 'lamb';
  if (pt.includes('beef') || t.includes('beef')) return 'beef';
  return 'other';
}

const decorated = products.map(p => ({
  ...p,
  type: getType(p.productType, p.title),
  cut: getCut(p.title, p.tags || []),
}));

// Build filter counts
const typeCounts = {
  all: decorated.length,
  beef: decorated.filter(p => p.type === 'beef').length,
  lamb: decorated.filter(p => p.type === 'lamb').length,
};

const cutLabels: Record<string, string> = {
  all: 'All cuts',
  mince: 'Mince',
  sausage: 'Sausages',
  steak: 'Steak',
  roast: 'Roasts',
  chops: 'Chops',
  'slow-cook': 'Slow-cook',
};

const cutCounts = Object.fromEntries(
  Object.keys(cutLabels).map(c => [
    c,
    c === 'all' ? decorated.length : decorated.filter(p => p.cut === c).length,
  ])
);

const philosophy = [
  { title: 'Grass-fed, pasture-grazed', body: 'Biodiverse soil, rich nutritional grass. The way meat was always meant to be raised.' },
  { title: 'Regenerative principles', body: 'Ecology as the first principle. Producing more from the land each year, not less.' },
  { title: 'No hormones, GMOs, antibiotics', body: 'Free from synthetic inputs. Just clean grass, clean water, and care.' },
  { title: 'Happy, healthy animals', body: 'Low stress handling, room to move, time to grow well. Better life, better meat.' },
];

const steps = [
  {
    n: '01',
    title: 'Choose your order',
    body: 'Select 1kg or more of premium Mangaroa Farms meat from our range. Place your order before 12pm Wednesdays for same week delivery. Any orders after this time will be shipped the following week.',
    note: '',
    icon: 'cart',
  },
  {
    n: '02',
    title: 'We pack your box',
    body: 'After you place your order, our team starts to assemble your box of premium frozen meat.',
    note: 'Please note, all meat is sent frozen. We do not recommend re-freezing if meat has thawed noticeably in the courier.',
    icon: 'box',
  },
  {
    n: '03',
    title: 'Delivery',
    body: 'Your order will be picked up on a Thursday morning by NZ Post. You will receive a tracking number when your package is scanned onboard.',
    note: 'Please note: unfortunately we cannot deliver to rural addresses, or the South Island.',
    icon: 'truck',
  },
  {
    n: '04',
    title: 'Enjoy',
    body: 'Savour your meal of Mangaroa Farms meat, knowing it was raised well and packed full of nutrients.',
    note: 'Recycle packaging: place all used packaging back into a box and return to us when you\'re ready.',
    icon: 'plate',
  },
];
---

<Layout title="Order Meat Online - Mangaroa Farms" description="Buy regenerative beef and lamb online from Mangaroa Farms. Pasture-raised in the Hutt Valley, delivered frozen across the North Island or pick up from the farm shop.">

  <Fragment slot="head">
    <ProductSchema products={products} />
    <BreadcrumbSchema items={[{ name: 'Order Online', href: '/order' }]} />
  </Fragment>

  <main>

    <!-- ═══ COMING SOON ANNOUNCEMENT BAR ═══ -->
    <div class="relative z-30 bg-mangaroa-gold-dark text-white px-4 py-3 sm:py-3.5 text-center text-[13px] sm:text-[14px] leading-snug">
      <span class="inline-block font-bold uppercase tracking-[0.2em] text-[10px] sm:text-[11px] mr-2 px-2 py-0.5 bg-white/15 rounded-sm">Coming Soon</span>
      Fresh meat from our new on-farm butchery launches in a few weeks. Frozen cuts from our previous butcher are available now.
    </div>

    <!-- ═══ PAGE HEADER (with transparent nav overlaid) ═══ -->
    <section class="bg-mangaroa-charcoal text-white relative overflow-hidden isolate pt-32 sm:pt-40 pb-16 sm:pb-20">
      <Header />
      <img src="/meat/cta-order.webp" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-55" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-b from-mangaroa-charcoal/55 via-mangaroa-charcoal/65 to-mangaroa-charcoal/80"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_30%,rgba(201,162,39,0.18),transparent_55%)] mix-blend-overlay"></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
        <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-white/85 mb-4 font-medium">Order online</p>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight mb-5">Regeneratively raised meat, delivered.</h1>
        <p class="text-white/85 text-base sm:text-lg max-w-2xl leading-[1.7] mb-2">
          North Island delivery now available. Or pick up from the farm shop.
        </p>
        <p class="text-white/70 text-[14px] sm:text-base max-w-2xl leading-[1.7]">
          Frozen cuts from our previous butcher available now. Fresh meat from the new on-farm butchery launches in a few weeks.
        </p>
      </div>
    </section>

    <!-- ═══ INTRO + 4 PHILOSOPHY POINTS (cream) ═══ -->
    <section class="bg-mangaroa-cream border-b border-mangaroa-gray-light/70">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
        <div class="max-w-3xl mb-10 sm:mb-14" data-reveal>
          <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">What you're buying</p>
          <p class="text-lg sm:text-xl text-mangaroa-charcoal leading-[1.65]">
            Mangaroa Farms livestock are raised naturally with care, in alignment with regenerative principles. Premium quality, superior tasting meat, nurtured on a wholesome diet of lush, diverse pasture. Free from stress, added hormones, GMOs, and antibiotics.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8" data-reveal>
          {philosophy.map(p => (
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-mangaroa-charcoal leading-[1.2] mb-2">{p.title}</h3>
              <p class="text-[14px] sm:text-[15px] text-mangaroa-gray leading-[1.6]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ FILTERS + PRODUCT GRID (white) ═══ -->
    <section class="bg-white" id="cabinet">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
        <div class="max-w-2xl mb-10 sm:mb-12" data-reveal>
          <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">Browse the cabinet</p>
          <h2 class="text-3xl sm:text-5xl font-semibold text-mangaroa-charcoal leading-[1.05] tracking-tight">{products.length} cuts in stock.</h2>
        </div>

        <!-- Filter bar -->
        <div class="filters mb-8 sm:mb-10 space-y-4 sm:space-y-5" data-reveal>
          <div>
            <p class="text-[12px] uppercase tracking-[0.2em] text-mangaroa-gray font-bold mb-2.5">Meat type</p>
            <div class="flex flex-wrap gap-2 filter-group" data-filter-group="type">
              <button type="button" class="filter-pill is-active" data-filter-value="all">All <span class="filter-count">({typeCounts.all})</span></button>
              <button type="button" class="filter-pill" data-filter-value="beef">Beef <span class="filter-count">({typeCounts.beef})</span></button>
              <button type="button" class="filter-pill" data-filter-value="lamb">Lamb <span class="filter-count">({typeCounts.lamb})</span></button>
            </div>
          </div>
          <div>
            <p class="text-[12px] uppercase tracking-[0.2em] text-mangaroa-gray font-bold mb-2.5">Cut</p>
            <div class="flex flex-wrap gap-2 filter-group" data-filter-group="cut">
              {Object.entries(cutLabels).map(([k, label]) => (
                <button type="button" class={`filter-pill ${k === 'all' ? 'is-active' : ''}`} data-filter-value={k}>
                  {label} <span class="filter-count">({cutCounts[k]})</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Empty state (shown when no products match) -->
        <p id="empty-state" class="hidden text-center py-12 text-mangaroa-gray text-lg">
          No cuts match your filters. Try a different combination.
        </p>

        {decorated.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-mangaroa-gray text-lg mb-4">No products listed at the moment.</p>
            <p class="text-mangaroa-gray">Check back soon, or visit the farm shop to see what is in the cabinet.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6" id="product-grid">
            {decorated.map((product) => (
              <a
                href={product.shopifyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="product-card group bg-white border border-mangaroa-gray-light/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all flex flex-col"
                data-type={product.type}
                data-cut={product.cut}
              >
                {product.image ? (
                  <div class="aspect-square overflow-hidden bg-mangaroa-paper">
                    <img
                      src={product.image}
                      alt={product.imageAlt}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-square bg-mangaroa-paper flex items-center justify-center">
                    <svg class="w-12 h-12 text-mangaroa-gray-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                <div class="p-5 sm:p-6 flex flex-col flex-1">
                  <p class="text-[11px] uppercase tracking-[0.2em] text-mangaroa-gold font-bold mb-2">{product.type === 'lamb' ? 'Lamb' : product.type === 'beef' ? 'Beef' : ''}</p>
                  <h3 class="font-semibold text-mangaroa-charcoal text-lg sm:text-xl leading-[1.15] mb-2">{product.title}</h3>
                  {product.description && (
                    <p class="text-[14px] text-mangaroa-gray leading-[1.6] mb-4 line-clamp-2 flex-1">{product.description}</p>
                  )}
                  <div class="flex items-center justify-between mt-auto">
                    <span class="text-mangaroa-charcoal font-semibold text-lg">{formatPrice(product.price, product.currency)}</span>
                    {product.availableForSale ? (
                      <span class="text-[11px] uppercase tracking-[0.2em] font-bold text-mangaroa-charcoal">In stock</span>
                    ) : (
                      <span class="text-[11px] uppercase tracking-[0.2em] font-bold bg-mangaroa-gray-light text-mangaroa-gray px-2 py-1 rounded-sm">Sold out</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- ═══ HOW IT WORKS — 4 step delivery flow (paper) ═══ -->
    <section class="bg-mangaroa-paper border-y border-mangaroa-gray-light/70">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
        <div class="max-w-2xl mb-12 sm:mb-14" data-reveal>
          <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium">How it works</p>
          <h2 class="text-3xl sm:text-5xl font-semibold text-mangaroa-charcoal leading-[1.05] tracking-tight mb-5">From cabinet to your kitchen.</h2>
          <p class="text-lg text-mangaroa-gray leading-[1.65]">Order online, packed by our crew, delivered by NZ Post across the North Island.</p>
        </div>

        <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
          {steps.map(s => (
            <li data-reveal class="flex flex-col">
              <div class="w-12 h-12 sm:w-14 sm:h-14 mb-5 text-mangaroa-charcoal border border-mangaroa-charcoal flex items-center justify-center rounded-full">
                {s.icon === 'cart' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
                )}
                {s.icon === 'box' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                )}
                {s.icon === 'truck' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
                )}
                {s.icon === 'plate' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
                )}
              </div>
              <p class="text-[12px] uppercase tracking-[0.25em] text-mangaroa-gold font-bold mb-2 font-mono tabular-nums">{s.n}</p>
              <h3 class="text-xl sm:text-2xl font-semibold text-mangaroa-charcoal leading-[1.15] mb-3">{s.title}</h3>
              <p class="text-[15px] text-mangaroa-gray leading-[1.65]">{s.body}</p>
              {s.note && (
                <p class="text-[13px] text-mangaroa-gray/80 leading-[1.6] mt-3 italic">* {s.note}</p>
              )}
            </li>
          ))}
        </ol>

      </div>
    </section>

    <!-- ═══ BULK + GOT QUESTIONS (cream) ═══ -->
    <section class="bg-mangaroa-cream">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-14 sm:py-20 text-center">
        <p class="text-[14px] sm:text-base uppercase tracking-[0.25em] text-mangaroa-gold mb-4 font-medium" data-reveal>Looking for more?</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-mangaroa-charcoal leading-[1.05] tracking-tight mb-5" data-reveal>Whole lamb or side of beef?</h2>
        <p class="text-lg text-mangaroa-gray leading-[1.65] mb-8" data-reveal>
          Custom bulk orders fill the freezer. Register interest and we'll work out timing, cuts, and pricing.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center" data-reveal>
          <a href="/bulk" class="inline-flex items-center justify-center gap-2 bg-mangaroa-charcoal hover:bg-mangaroa-ink text-white px-7 py-3.5 rounded-full text-base font-semibold transition-all" style="min-height:48px;">
            Register bulk interest
            <span aria-hidden="true">→</span>
          </a>
          <a href="mailto:online@mangaroa.org" class="inline-flex items-center justify-center gap-2 bg-white border border-mangaroa-gold text-mangaroa-charcoal hover:bg-mangaroa-gold hover:text-white px-7 py-3.5 rounded-full text-base font-semibold transition-all" style="min-height:48px;">
            Got questions? Email us
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style is:global>
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-mangaroa-gray-light);
    border-radius: 999px;
    background: white;
    color: var(--color-mangaroa-charcoal);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    line-height: 1;
  }
  .filter-pill:hover {
    border-color: color-mix(in srgb, var(--color-mangaroa-gold) 60%, var(--color-mangaroa-gray-light));
    background: color-mix(in srgb, var(--color-mangaroa-gold) 5%, white);
  }
  .filter-pill.is-active {
    background: var(--color-mangaroa-charcoal);
    color: white;
    border-color: var(--color-mangaroa-charcoal);
  }
  .filter-pill .filter-count {
    color: var(--color-mangaroa-gray);
    font-weight: 400;
    font-size: 0.8125rem;
  }
  .filter-pill.is-active .filter-count { color: rgba(255,255,255,0.65); }
  .product-card.is-hidden { display: none; }
</style>

<script>
  // Scroll-reveal observer
  const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => io.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('is-visible'));
  }

  // Product filter
  const groups = document.querySelectorAll<HTMLElement>('.filter-group');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.product-card'));
  const emptyState = document.getElementById('empty-state');
  const state = { type: 'all', cut: 'all' };

  function applyFilters() {
    let visible = 0;
    cards.forEach(c => {
      const t = c.getAttribute('data-type') || '';
      const cu = c.getAttribute('data-cut') || '';
      const matchType = state.type === 'all' || t === state.type;
      const matchCut = state.cut === 'all' || cu === state.cut;
      const show = matchType && matchCut;
      c.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });
    if (emptyState) emptyState.classList.toggle('hidden', visible !== 0);
  }

  groups.forEach(group => {
    const groupName = group.getAttribute('data-filter-group') as 'type' | 'cut' | null;
    group.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        const value = btn.getAttribute('data-filter-value') || 'all';
        if (!groupName) return;
        state[groupName] = value;
        group.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        applyFilters();
      });
    });
  });
</script>
